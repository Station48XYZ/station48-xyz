---
import { Image } from "astro:assets";
import logo from "../assets/favicon.png";
import { DISCORD_URL, KINETIC_HOSTING_REFERRAL_URL, STATION48_SERVER_IP, STATION48_SERVER_PORT } from "../consts";
import { getServerStatus } from "../lib/getServerStatus";

interface Props {
  eager?: boolean;
}

const { eager = false } = Astro.props;

const host = STATION48_SERVER_IP;

const status = await getServerStatus({
    host,
    port: STATION48_SERVER_PORT,
    options: {
        query: true
    }
});
---

<footer
  class="flex flex-col sm:flex-row items-center justify-between py-4 px-6 h-block-5 sm:h-block-4 md:h-block-3 bg-block-bedrock bg-light-level-4"
>
  <header
    class="flex align-center items-center gap-4 w-full sm:w-[60%] my-auto"
  >
    <Image
      src={logo}
      alt="Station48 Logo"
      class="h-full max-w-[30ch] m-[-14px]"
      loading={eager ? "eager" : "lazy"}
      width={64}
      height={64}
    />
    <pre set:html={status?.motd?.html || "Server MOTD Unavailable"} />
  </header>
  <nav
    class="flex flex-col items-center sm:items-end justify-center gap-2 sm:gap-1 text-link w-full"
  >
    <a href="/rss.xml" class="link">RSS Feed</a>
    <a href={KINETIC_HOSTING_REFERRAL_URL} class="link">
      Hosting by Kinetic Hosting ↗
    </a>
    <a href="https://astro.build" class="link">Website Built with Astro ↗</a>
    <a href={DISCORD_URL} class="link">Our Discord ↗</a>
  </nav>
</footer>
